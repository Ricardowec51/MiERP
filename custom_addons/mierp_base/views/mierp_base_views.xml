<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Company Form View Extension -->
        <record id="view_company_mierp_form" model="ir.ui.view">
            <field name="name">res.company.form.mierp</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="MiERP" name="mierp_page">
                        <group>
                            <field name="mierp_version"/>
                            <field name="mierp_brand_name"/>
                            <field name="mierp_module_enabled"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
