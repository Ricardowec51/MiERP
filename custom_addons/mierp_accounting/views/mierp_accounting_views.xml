<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Account Move Form View Extension -->
        <record id="view_move_form_mierp" model="ir.ui.view">
            <field name="name">account.move.form.mierp</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="MiERP" name="mierp_page">
                        <group>
                            <field name="mierp_document_type"/>
                            <field name="mierp_custom_reference"/>
                            <field name="mierp_department"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
