<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Product Template Form View Extension -->
        <record id="view_product_template_form_mierp" model="ir.ui.view">
            <field name="name">product.template.form.mierp</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="MiERP" name="mierp_page">
                        <group>
                            <field name="mierp_sku_custom"/>
                            <field name="mierp_storage_location"/>
                            <field name="mierp_reorder_level"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

        <!-- Stock Picking Form View Extension -->
        <record id="view_picking_form_mierp" model="ir.ui.view">
            <field name="name">stock.picking.form.mierp</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="MiERP" name="mierp_page">
                        <group>
                            <field name="mierp_movement_type"/>
                            <field name="mierp_notes"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
